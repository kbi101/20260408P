# QuantEdge Studio: Environment Template
# Copy this to .env.local and fill in your credentials

# Database Configuration
DB_USER=postgres
DB_PASSWORD=REPLACED_FOR_GITHUB
DB_NAME=crystal_db
DB_HOST=localhost
DB_URL=host=localhost port=5432 dbname=crystal_db user=postgres password=REPLACED_FOR_GITHUB options='-c search_path=quant'

# Infrastructure
REDIS_URL=redis://localhost:6379
TEMPORAL_HOST=localhost:7233
QUESTDB_HOST=localhost

# Market Data API Keys
ALPHA_VANTAGE_API_KEY=YOUR_KEY_HERE
ALPHA_VANTAGE_BASE_URL=https://www.alphavantage.co

# Development Settings
ENVIRONMENT=development
LOG_LEVEL=INFO
